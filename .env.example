# Required only when running new benchmarks locally.
OPENROUTER_API_KEY=your-openrouter-api-key

# Independent judge. Do not set this to Qwen or Gemma.
JUDGE_MODEL=openai/gpt-4.1-mini

# Protects the hosted Streamlit app.
APP_PASSWORD=replace-with-a-strong-password

# Local default: data/llm_eval.db
# Render with a persistent disk: /var/data/llm_eval.db
DATABASE_PATH=data/llm_eval.db

OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_APP_TITLE=Greek LLM Evaluation
REQUEST_TIMEOUT_SECONDS=180
MAX_API_RETRIES=2
RETRY_BACKOFF_SECONDS=1.0
PAUSE_BETWEEN_REQUESTS=0.5
BENCHMARK_MAX_WORKERS=4
